<?xml version="1.0"?>
<ruleset name="PrestaShopVersionChecker">

  <config name="testVersion" value="5.6"/>

  <file>src</file>
  <file>tests</file>

  <exclude-pattern>vendor/*</exclude-pattern>

  <arg name="colors"/>
  <arg value="p"/>

  <rule ref="PSR2">
    <exclude name="Generic.Files.LineLength"/>
  </rule>
  <rule ref="PHPCompatibility"/>

</ruleset>
