{
    "name": "rubenmartindev/prestashop-version-checker",
    "description": "A lightweight library to check and compare PrestaShop versions with a fluent API",
    "keywords": ["prestashop", "version", "checker", "compare", "semver"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Rubén Martín",
            "email": "hola@rubenmartin.dev"
        }
    ],
    "require": {
        "php": ">=5.6.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^5.7",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "RubenMartinDev\\PrestaShopVersionChecker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RubenMartinDev\\PrestaShopVersionChecker\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "5.6.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
